# ============================================
# MindBridge - Environment Configuration
# ============================================
# Copy this file to .env and configure values

# SECURITY (REQUIRED: change SECRET_KEY in production!)
SECRET_KEY=change-this-to-a-long-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# DATABASE
DATABASE_URL=sqlite+aiosqlite:///./data/emotional_support.db
# For PostgreSQL (optional upgrade):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/mindbridge

# AI MODELS (HuggingFace IDs - downloaded automatically on first run)
EMOTION_MODEL=j-hartmann/emotion-english-distilroberta-base
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# LOCAL LLM (optional - leave empty to use template responses)
# LLM_MODEL=/path/to/model.gguf

# RAG PIPELINE
KNOWLEDGE_BASE_DIR=./knowledge_base
ESCALATION_THRESHOLD=0.65

# LOGGING
LOG_FILE=system_events.log

# API URL (for frontend)
API_URL=http://localhost:8000
